# Copy to test-app/.env (or set in repo-root .env — server loads both).
#
# ROOT_API_KEY must be the full token string (three underscore-separated parts):
#   test_<token_id>_<secret>   — sandbox / dev
#   live_<token_id>_<secret>    — production
# Example shape (not real): test_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx_abc123xyz
# A bare UUID alone will fail with INVALID_TOKEN from the API (and the SDK warns on startup).

ROOT_API_KEY=
ROOT_BASE_URL=https://api.useroot.com

# Optional — skip auto-discovery in the SDK
# ROOT_DEFAULT_SUBACCOUNT_ID=

# Optional — local server port (default 3847)
# TEST_APP_PORT=3847
